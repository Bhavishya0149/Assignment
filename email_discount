import nodemailer from "nodemailer";

export default defineComponent({
  async run({ steps }) {

    const { email, firstName } = steps.connection_check.$return_value;

    const transporter = nodemailer.createTransport({
      host: process.env.SMTP_HOST,
      port: 587,
      secure: false,
      auth: {
        user: process.env.SMTP_USER,
        pass: process.env.SMTP_PASS,
      },
    });

    await transporter.sendMail({
      from: process.env.SMTP_USER,
      to: email,
      subject: "A New Discount Has Been Unlocked!",
      text: `Hi ${firstName},

Great news!

As a valued customer, you've unlocked a special discount for your next purchase.

We look forward to serving you again soon.

Happy Shopping!

Best Regards,
Your Team`,
    });

    console.log(`Discount email sent to ${email}`);
  },
});
